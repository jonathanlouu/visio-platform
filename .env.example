# Copier ce fichier en .env et remplir les valeurs

# Port du serveur
PORT=3000

# Secret pour les sessions (changer par une longue chaîne aléatoire)
SESSION_SECRET=changez-moi-par-une-chaine-aleatoire-longue

# URL publique du serveur (pour les liens SMS)
# En local: http://localhost:3000
# En production: https://votre-domaine.com
APP_URL=http://localhost:3000

# Identifiants des utilisateurs (format: login:motdepasse, séparés par virgule)
USERS=admin:motdepasse123,technicien1:pass456

# Informations de votre société (pour le PDF)
COMPANY_NAME=Mon Entreprise EnR
COMPANY_ADDRESS=12 rue de l'Énergie, 75001 Paris
COMPANY_PHONE=01 23 45 67 89
COMPANY_EMAIL=contact@mon-entreprise.fr

# Twilio (pour l'envoi de SMS)
# Créer un compte sur twilio.com, section "Phone Numbers"
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+33xxxxxxxxx
